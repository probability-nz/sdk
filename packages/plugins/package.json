{
  "name": "@probability-nz/plugins",
  "version": "0.1.0",
  "description": "SDK for building probability.nz plugins",
  "keywords": [
    "automerge",
    "board-game",
    "plugin",
    "probability",
    "sdk"
  ],
  "license": "AGPL-3.0-only",
  "author": "Garbo Succus",
  "repository": {
    "type": "git",
    "url": "https://github.com/probability-nz/sdk",
    "directory": "packages/plugins"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "oxlint -c ../../.oxlintrc.json && tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@probability-nz/lib": "workspace:*",
    "@probability-nz/types": "workspace:*"
  },
  "devDependencies": {
    "@automerge/automerge": "^3.2.3",
    "@automerge/react": "2.5.3",
    "@tanstack/react-pacer": "^0.20.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-store": "^0.9.2",
    "@tanstack/store": "^0.9.2",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.13",
    "jsdom": "^28.0.0",
    "react": "^19.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@automerge/automerge": "^3",
    "@automerge/react": "^2.5.3",
    "@tanstack/react-pacer": "^0.20",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-store": "^0.9",
    "@tanstack/store": "^0.9",
    "react": "^18 || ^19"
  }
}
