{
  "name": "@probability-nz/types",
  "version": "0.0.0",
  "description": "Types and JSON schema for Probability",
  "keywords": [
    "plugin",
    "probability",
    "types",
    "schema"
  ],
  "license": "AGPL-3.0-only",
  "author": "Garbo Succus <hello@garbo.succus.games>",
  "repository": {
    "type": "git",
    "url": "https://github.com/probability-nz/sdk",
    "directory": "packages/types"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./analog.json": "./dist/analog.json"
  },
  "scripts": {
    "build": "tsc && typia generate --input scripts/generate-schema --output dist/.generated --project tsconfig.schema.json && tsx dist/.generated/index.ts",
    "lint": "oxlint -c ../../.oxlintrc.json && tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@automerge/automerge-repo": "^2.5.3"
  },
  "devDependencies": {
    "@automerge/automerge": "^3",
    "@types/node": "^25.4.0",
    "@types/three": "^0.183.1",
    "@typia/unplugin": "12.0.0-dev.20260312-3",
    "ajv": "^8",
    "tsx": "^4",
    "typescript": "^5.9.3",
    "typia": "12.0.0-dev.20260312-3",
    "vitest": "^4"
  }
}
